{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "*": "allow",
    "task": "deny"
  },
  "autoupdate": false,
  "disabled_providers": ["opencode"],
  "default_agent": "general",
  // Default model for every agent session. Pinned to GLM-5 Turbo via the
  // `kortix` router — 202k context, much cheaper than Claude Sonnet, and
  // large-context so the "max context 32768" overflow class is structurally
  // impossible. Per-agent overrides (see ./agents/*.md) can select a
  // different model without touching this default.
  "model": "kortix/glm-turbo",
  // Shared system prompt base — always injected into every agent session.
  // Agent-specific persona/loop/rules live in ./agents/<name>.md.
  "instructions": ["./kortix-system.md"],
  "agent": {
    "build": { "disable": true },
    "plan": { "disable": true },
    "explore": { "disable": true }
  },
  "provider": {
    // Anthropic — baked in so `anthropic/claude-sonnet-4-6` remains a valid
    // provider reference across image updates. The previous behaviour of
    // adding this via `PATCH /config` at runtime did not survive image swaps
    // because /ephemeral/ is replaced on update. Keeping the provider here
    // keeps the user's selected model resolvable without a re-patch.
    "anthropic": {
      "npm": "@ai-sdk/anthropic",
      "env": ["ANTHROPIC_API_KEY"],
      "options": {
        "apiKey": "{env:ANTHROPIC_API_KEY}"
      },
      "models": {
        "claude-sonnet-4-6": {
          "name": "Claude Sonnet 4.6",
          "id": "claude-sonnet-4-6",
          "family": "anthropic"
        }
      }
    },
    "kortix-yolo": {
      "npm": "@ai-sdk/anthropic",
      "env": ["KORTIX_YOLO_API_KEY", "KORTIX_YOLO_URL"],
      "options": {
        "baseURL": "{env:KORTIX_YOLO_URL}",
        "apiKey": "{env:KORTIX_YOLO_API_KEY}"
      },
      "models": {
        "kortix-yolo/fast": {
          "name": "Fast",
          "id": "kortix-yolo/fast",
          "family": "kortix-yolo"
        },
        "kortix-yolo/think": {
          "name": "Think",
          "id": "kortix-yolo/think",
          "family": "kortix-yolo"
        }
      }
    },
    // Featherless — uncensored / abliterated / ERP-oriented models. Mirrors
    // what hosted kortix.com exposes under its `featherless` provider. These
    // are the steady-state set for adult / roleplay / safety-bypass use
    // cases; base coding / assistant work should keep using `kortix/*` or
    // `anthropic/*`. Provider is OpenAI-compatible at api.featherless.ai/v1.
    "featherless": {
      "npm": "@ai-sdk/openai-compatible",
      "env": ["FEATHERLESS_API_KEY"],
      "options": {
        "baseURL": "https://api.featherless.ai/v1",
        "apiKey": "{env:FEATHERLESS_API_KEY}"
      },
      "models": {
        "dphn/Dolphin-Mistral-24B-Venice-Edition": { "name": "Dolphin Mistral 24B Venice (Uncensored)", "id": "dphn/Dolphin-Mistral-24B-Venice-Edition", "family": "featherless", "limit": { "context": 32768, "output": 8192 } },
        "huihui-ai/Llama-3.3-70B-Instruct-abliterated": { "name": "Llama 3.3 70B Abliterated", "id": "huihui-ai/Llama-3.3-70B-Instruct-abliterated", "family": "featherless", "limit": { "context": 32768, "output": 8192 } },
        "huihui-ai/DeepSeek-R1-Distill-Llama-70B-abliterated": { "name": "DeepSeek R1 70B Abliterated", "id": "huihui-ai/DeepSeek-R1-Distill-Llama-70B-abliterated", "family": "featherless", "limit": { "context": 32768, "output": 8192 } },
        "zetasepic/Qwen2.5-72B-Instruct-abliterated": { "name": "Qwen 2.5 72B Abliterated", "id": "zetasepic/Qwen2.5-72B-Instruct-abliterated", "family": "featherless", "limit": { "context": 32768, "output": 8192 } },
        "mlabonne/Hermes-3-Llama-3.1-70B-lorablated": { "name": "Hermes 3 70B Lorablated", "id": "mlabonne/Hermes-3-Llama-3.1-70B-lorablated", "family": "featherless", "limit": { "context": 32768, "output": 8192 } },
        "NousResearch/Hermes-4-70B": { "name": "Hermes 4 70B", "id": "NousResearch/Hermes-4-70B", "family": "featherless", "limit": { "context": 32768, "output": 8192 } },
        "sh0ck0r/L3.3-70B-Euryale-v2.3-heretic": { "name": "Euryale v2.3 Heretic 70B", "id": "sh0ck0r/L3.3-70B-Euryale-v2.3-heretic", "family": "featherless", "limit": { "context": 32768, "output": 8192 } },
        "sh0ck0r/Forgotten-Safeword-70B-v5.0-heretic": { "name": "Forgotten Safeword 70B", "id": "sh0ck0r/Forgotten-Safeword-70B-v5.0-heretic", "family": "featherless", "limit": { "context": 32768, "output": 8192 } },
        "sh0ck0r/L3.3-MS-Nevoria-70b-heretic2": { "name": "Nevoria 70B Heretic2", "id": "sh0ck0r/L3.3-MS-Nevoria-70b-heretic2", "family": "featherless", "limit": { "context": 32768, "output": 8192 } },
        "Sao10K/L3.3-70B-Euryale-v2.3": { "name": "Euryale v2.3 70B", "id": "Sao10K/L3.3-70B-Euryale-v2.3", "family": "featherless", "limit": { "context": 32768, "output": 8192 } },
        "Sao10K/32B-Qwen2.5-Kunou-v1": { "name": "Kunou 32B", "id": "Sao10K/32B-Qwen2.5-Kunou-v1", "family": "featherless", "limit": { "context": 32768, "output": 8192 } },
        "NeverSleep/Lumimaid-v0.2-70B": { "name": "Lumimaid v0.2 70B", "id": "NeverSleep/Lumimaid-v0.2-70B", "family": "featherless", "limit": { "context": 32768, "output": 8192 } },
        "NeverSleep/Lumimaid-v0.2-12B": { "name": "Lumimaid v0.2 12B", "id": "NeverSleep/Lumimaid-v0.2-12B", "family": "featherless", "limit": { "context": 32768, "output": 8192 } },
        "openerotica/writing-roleplay-20k-context-nemo-12b-v1.0": { "name": "OpenErotica Nemo 12B", "id": "openerotica/writing-roleplay-20k-context-nemo-12b-v1.0", "family": "featherless", "limit": { "context": 20480, "output": 4096 } },
        "CrucibleLab/L3.3-Dark-Ages-70b-v0.1": { "name": "Dark Ages 70B", "id": "CrucibleLab/L3.3-Dark-Ages-70b-v0.1", "family": "featherless", "limit": { "context": 32768, "output": 8192 } },
        "ArliAI/QwQ-32B-ArliAI-RpR-v4": { "name": "ArliAI RpR v4 32B", "id": "ArliAI/QwQ-32B-ArliAI-RpR-v4", "family": "featherless", "limit": { "context": 32768, "output": 8192 } }
      }
    },
    // OpenRouter — single-entry carve-out for the uncensored Dolphin Venice
    // free model. The broader OpenRouter catalog is intentionally not mirrored
    // here; the `kortix` router already proxies most popular OpenRouter models
    // with cost accounting. This provider exists so adult/roleplay workflows
    // have a zero-cost fallback when Featherless auth is unavailable.
    "openrouter": {
      "npm": "@openrouter/ai-sdk-provider",
      "env": ["OPENROUTER_API_KEY"],
      "options": {
        "apiKey": "{env:OPENROUTER_API_KEY}"
      },
      "models": {
        "cognitivecomputations/dolphin-mistral-24b-venice-edition:free": {
          "name": "Dolphin Mistral 24B Venice (free, uncensored)",
          "id": "cognitivecomputations/dolphin-mistral-24b-venice-edition:free",
          "family": "openrouter",
          "cost": { "input": 0, "output": 0 },
          "limit": { "context": 32768, "output": 8192 }
        }
      }
    },
    "kortix": {
      "npm": "@ai-sdk/openai-compatible",
      "env": ["KORTIX_TOKEN", "KORTIX_API_URL"],
      "options": {
        "baseURL": "{env:KORTIX_API_URL}/v1/router",
        "apiKey": "{env:KORTIX_TOKEN}"
      },
      "models": {
        "minimax-m27": {
          "name": "MiniMax M2.7",
          "id": "minimax/minimax-m2.7",
          "family": "kortix",
          "cost": { "input": 0.30, "output": 1.20 },
          "limit": { "context": 204800, "output": 131072 }
        },
        "glm-turbo": {
          "name": "GLM-5 Turbo",
          "id": "z-ai/glm-5-turbo",
          "family": "kortix",
          "cost": { "input": 1.20, "output": 4.00 },
          "limit": { "context": 202752, "output": 131072 }
        },
        "kimi": {
          "name": "Kimi K2.5",
          "id": "moonshotai/kimi-k2.5",
          "family": "kortix",
          "cost": { "input": 0.45, "output": 2.20 },
          "limit": { "context": 262144, "output": 65535 }
        },
        "minimax": {
          "name": "MiniMax M2.5",
          "id": "minimax/minimax-m2.5",
          "family": "kortix",
          "cost": { "input": 0.20, "output": 1.17 },
          "limit": { "context": 196608, "output": 65536 }
        }
      }
    }
  },
  "plugin": [
    "./plugin/kortix-system/kortix-system.ts",
    "./plugin/opencode-caveman-plugin/opencode-caveman-plugin.ts"
  ],
  "mcp": {
    // ── Base MCP set ───────────────────────────────────────────────────────
    // Every agent session starts with these attached so skills don't have to
    // pay the cost of bootstrapping them per-session. Additional MCPs are
    // expected to be attached on demand by the skill-activation layer.
    // Tokens come from /persistent/secrets/ via `97-secrets-to-s6-env.sh`.
    // URLs for self-hosted services default to the garzaos.cloud endpoints
    // but can be overridden per-install via the `_URL` env vars.
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "enabled": true
    },
    "composio": {
      "type": "remote",
      "url": "https://connect.composio.dev/mcp",
      "headers": {
        "x-consumer-api-key": "{env:COMPOSIO_MCP_API_KEY}"
      },
      "enabled": true
    },
    "firecrawl": {
      "type": "remote",
      "url": "{env:FIRECRAWL_MCP_URL}",
      "headers": {
        "Authorization": "Bearer {env:FIRECRAWL_API_KEY}"
      },
      "enabled": true
    },
    "tavily": {
      "type": "remote",
      "url": "{env:TAVILY_MCP_URL}",
      "headers": {
        "Authorization": "Bearer {env:TAVILY_API_KEY}"
      },
      "enabled": true
    },
    "proton": {
      "type": "remote",
      "url": "https://protonmail.garzaos.cloud/mcp",
      "headers": {
        "Authorization": "Bearer {env:PROTONMAIL_MCP_TOKEN}"
      },
      "enabled": true
    },
    "bitwarden": {
      "type": "remote",
      "url": "{env:VAULT_MCP_URL}",
      "headers": {
        "Authorization": "Bearer {env:VAULT_MCP_BEARER_TOKEN}"
      },
      "enabled": true
    },
    "beeper": {
      "type": "remote",
      "url": "{env:BEEPER_MCP_URL}",
      "headers": {
        "Authorization": "Bearer {env:BEEPER_MCP_TOKEN}"
      },
      "enabled": true
    }
  }
}
